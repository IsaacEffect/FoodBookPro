@{
    ViewData["Title"] = "Home Page";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<div class="text-center mt-5">
    <h1 class="display-4 fw-bold">¿Qué quieres comer hoy?</h1>
    <p class="lead text-muted">Busca entre los mejores restaurantes de tu zona.</p>

    <div class="row justify-content-center mt-5">
        <div class="col-md-9">
            <div class="card shadow-lg p-3 border-0" style="border-radius: 50px;">
                <form asp-controller="Restaurant" asp-action="Index" method="get" class="row g-2 align-items-center">
                    <div class="col-md-5">
                        <div class="input-group">
                            <span class="input-group-text bg-transparent border-0"><i class="fas fa-utensils text-primary"></i></span>
                            <input type="text" name="searchTerm" class="form-control border-0 bg-transparent" placeholder="Restaurante..." value="@ViewBag.SearchTerm">
                        </div>
                    </div>
                    <div class="col-md-4 border-start">
                        <div class="input-group">
                            <span class="input-group-text bg-transparent border-0"><i class="fas fa-map-marker-alt text-danger"></i></span>
                            <input type="text" name="location" class="form-control border-0 bg-transparent" placeholder="Ciudad o zona..." value="@ViewBag.Location">
                        </div>
                    </div>
                    <div class="col-md-3">
                        <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill shadow-sm py-2">
                            <i class="fas fa-search me-2"></i> Buscar
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="container mt-5 pt-5 text-center">
    <div class="row text-muted">
        <div class="col-md-4"><i class="fas fa-truck fa-2x mb-2"></i><p>Entrega rápida</p></div>
        <div class="col-md-4"><i class="fas fa-star fa-2x mb-2"></i><p>Los mejores calificados</p></div>
        <div class="col-md-4"><i class="fas fa-wallet fa-2x mb-2"></i><p>Precios justos</p></div>
    </div>
</div>