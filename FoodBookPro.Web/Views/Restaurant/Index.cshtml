@model List<FoodBookPro.Data.Entities.Restaurant>

@{
    ViewData["Title"] = "Explorar Restaurantes";
}

<div class="container mt-4">
    <h2 class="mb-4 text-center">Encuentra tu próximo lugar favorito</h2>

    <div class="card shadow-sm p-4 mb-5 bg-white rounded">
        <form asp-action="Index" method="get" class="row g-3">
            <div class="col-md-5">
                <label class="form-label fw-bold">Nombre del Restaurante</label>
                <input type="text" name="searchTerm" class="form-control" placeholder="Ej: Pizza Planeta..." value="@ViewBag.SearchTerm">
            </div>
            <div class="col-md-5">
                <label class="form-label fw-bold">Ciudad o Zona</label>
                <input type="text" name="location" class="form-control" placeholder="Ej: Santo Domingo..." value="@ViewBag.Location">
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100 shadow-sm">
                    <i class="fas fa-search"></i> Buscar
                </button>
            </div>
        </form>
    </div>

    <div class="row">
        @if (Model.Any())
        {
            @foreach (var item in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 border-0 shadow-sm hover-shadow">
                        <img src="@item.ImageUrl" class="card-img-top" alt="@item.Name" style="height: 200px; object-fit: cover; border-radius: 10px 10px 0 0;">

                        <div class="card-body">
                            <h5 class="card-title fw-bold">@item.Name</h5>
                            <p class="text-muted mb-2"><i class="fas fa-utensils me-2"></i>@item.CuisineType • @item.City</p>

                            <div class="d-flex justify-content-between align-items-center">
                                <span class="badge bg-warning text-dark">
                                    <i class="fas fa-star me-1"></i> @item.Rating
                                </span>
                                <a href="#" class="btn btn-outline-primary btn-sm rounded-pill">Ver Menú</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <h4 class="text-muted">No encontramos restaurantes que coincidan con tu búsqueda.</h4>
            </div>
        }
    </div>

    @if (ViewBag.TotalPages > 1)
    {
        <nav aria-label="Navegación de resultados" class="mt-4">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@i"
                           asp-route-searchTerm="@ViewBag.SearchTerm"
                           asp-route-location="@ViewBag.Location">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>