@model FoodBookPro.Web.Models.OwnerOrderListViewModel
@using FoodBookPro.Data.Entities
@{
    ViewData["Title"] = "Panel de Órdenes";
    var countPendientes = Model.Orders.Count(o => o.Estado == EstadoOrden.Pendiente);
}

<h2>Panel de Órdenes</h2>

<div id="nuevaOrdenBadge" class="alert alert-warning d-none" role="alert">
    <strong>Nueva orden pendiente.</strong> <a href="#" onclick="document.getElementById('nuevaOrdenBadge').classList.add('d-none'); location.reload();">Ver</a>
</div>

<form method="get" asp-action="Index" class="mb-4 p-3 bg-light rounded">
    <div class="row g-3">
        <div class="col-md-3">
            <label class="form-label">Estado</label>
            <select name="estado" class="form-select">
                <option value="">Todos</option>
                @foreach (EstadoOrden e in Enum.GetValues(typeof(EstadoOrden)))
                {
                    <option value="@((int)e)" selected="@(Model.FiltroEstado == e)">@e</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label">Retiro desde</label>
            <input type="datetime-local" name="horaRetiroDesde" class="form-control" value="@(Model.FiltroHoraRetiroDesde?.ToString("yyyy-MM-ddTHH:mm"))" />
        </div>
        <div class="col-md-2">
            <label class="form-label">Retiro hasta</label>
            <input type="datetime-local" name="horaRetiroHasta" class="form-control" value="@(Model.FiltroHoraRetiroHasta?.ToString("yyyy-MM-ddTHH:mm"))" />
        </div>
        <div class="col-md-2 d-flex align-items-end"><button type="submit" class="btn btn-primary">Filtrar</button></div>
        <div class="col-md-2 d-flex align-items-end"><a asp-action="Kitchen" class="btn btn-success">Vista Cocina</a></div>
    </div>
</form>

@if (Model.Orders.Count == 0)
{
    <p>No hay órdenes.</p>
}
else
{
    <table class="table">
        <thead><tr><th>#</th><th>Fecha</th><th>Retiro</th><th>Restaurante</th><th>Estado</th><th>Total</th><th>Timer</th><th></th></tr></thead>
        <tbody>
            @foreach (var order in Model.Orders)
            {
                <tr>
                    <td>@order.Id</td>
                    <td>@order.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@(order.HoraRetiro?.ToString("HH:mm") ?? "-")</td>
                    <td>@order.RestauranteNombre</td>
                    <td><span class="badge bg-secondary">@order.Estado</span></td>
                    <td>@order.Total.ToString("C")</td>
                    <td>
                        @if (order.Estado == EstadoOrden.Preparando && order.FechaPreparacionInicio.HasValue)
                        { <span class="timer" data-inicio="@order.FechaPreparacionInicio.Value.ToString("O")">--:--</span> }
                        else { <span>-</span> }
                    </td>
                    <td><a asp-action="Detail" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary">Detalle</a></td>
                </tr>
            }
        </tbody>
    </table>
}

@section Scripts {
<script>
let ultimoCountPendientes = @countPendientes;
function beep() { try { const c = new (window.AudioContext || window.webkitAudioContext)(), o = c.createOscillator(), g = c.createGain(); o.connect(g); g.connect(c.destination); o.frequency.value = 880; g.gain.value = 0.3; o.start(); o.stop(c.currentTime + 0.15); } catch(e) {} }
function tickTimers() { document.querySelectorAll('.timer').forEach(el => { const d = Math.floor((Date.now() - new Date(el.dataset.inicio)) / 1000); el.textContent = Math.floor(d/60).toString().padStart(2,'0') + ':' + (d%60).toString().padStart(2,'0'); }); }
function poll() {
    fetch('@Url.Action("GetPendingCount", "OwnerOrders")').then(r => r.json()).then(data => {
        if (data.count > ultimoCountPendientes) { document.getElementById('nuevaOrdenBadge').classList.remove('d-none'); beep(); }
        ultimoCountPendientes = data.count;
    });
}
setInterval(tickTimers, 1000); setInterval(poll, 5000); tickTimers();
</script>
}
