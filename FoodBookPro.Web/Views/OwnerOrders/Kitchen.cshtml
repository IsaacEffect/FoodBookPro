@model List<FoodBookPro.Data.Entities.Order>
@using FoodBookPro.Data.Entities
@{
    ViewData["Title"] = "Vista Cocina";
}

<h2>Vista Cocina</h2>
<p class="text-muted">Ordenes confirmadas y en preparacion. Ordenadas por hora de retiro.</p>

<div class="mb-3">
    <a asp-action="Index" class="btn btn-secondary">Panel Ordenes</a>
</div>

@if (Model.Count == 0)
{
    <p>No hay ordenes en preparacion.</p>
}
else
{
    <div class="row g-3">
        @foreach (var order in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card @(order.Estado == EstadoOrden.Preparando ? "border-warning" : "border-primary") h-100">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <strong>Orden #@order.Id</strong>
                        <span class="badge @(order.Estado == EstadoOrden.Preparando ? "bg-warning" : "bg-info")">@order.Estado</span>
                    </div>
                    <div class="card-body">
                        <p class="mb-1"><strong>Retiro:</strong> @(order.HoraRetiro?.ToString("HH:mm") ?? "-")</p>
                        @if (order.Estado == EstadoOrden.Preparando && order.FechaPreparacionInicio.HasValue)
                        {
                            <p class="mb-2">
                                <strong>Timer:</strong>
                                <span class="timer fs-4 text-warning" data-inicio="@order.FechaPreparacionInicio.Value.ToString("O")">--:--</span>
                            </p>
                        }
                        <hr />
                        <ul class="list-unstyled mb-0">
                            @foreach (var item in order.Items)
                            {
                                <li>@item.Cantidad x @item.ProductoNombre</li>
                            }
                        </ul>
                        <hr />
                        <p class="mb-0"><strong>Total: @order.Total.ToString("C")</strong></p>
                        @if (order.Estado == EstadoOrden.Confirmada)
                        {
                            <form asp-controller="OwnerOrders" asp-action="UpdateStatus" asp-route-id="@order.Id" method="post" class="mt-2">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="accion" value="preparando" />
                                <button type="submit" class="btn btn-warning btn-sm w-100">Iniciar Preparacion</button>
                            </form>
                        }
                        @if (order.Estado == EstadoOrden.Preparando)
                        {
                            <form asp-controller="OwnerOrders" asp-action="UpdateStatus" asp-route-id="@order.Id" method="post" class="mt-2">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="accion" value="lista" />
                                <button type="submit" class="btn btn-success btn-sm w-100">Marcar Lista</button>
                            </form>
                        }
                    </div>
                    <div class="card-footer">
                        <a asp-action="Detail" asp-route-id="@order.Id" class="btn btn-outline-secondary btn-sm">Ver detalle</a>
                    </div>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    <script>
        function actualizarTimers() {
            document.querySelectorAll('.timer').forEach(function(el) {
                const inicio = new Date(el.dataset.inicio);
                const diff = Math.floor((Date.now() - inicio.getTime()) / 1000);
                const m = Math.floor(diff / 60);
                const s = diff % 60;
                el.textContent = (m + '').padStart(2, '0') + ':' + (s + '').padStart(2, '0');
            });
        }
        setInterval(actualizarTimers, 1000);
        actualizarTimers();
    </script>
}
