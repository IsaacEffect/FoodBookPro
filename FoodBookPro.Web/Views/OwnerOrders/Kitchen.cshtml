@model List<FoodBookPro.Data.Entities.Order>
@using FoodBookPro.Data.Entities
@{
    ViewData["Title"] = "Vista Cocina";
}

<h2>Vista Cocina</h2>
<p class="text-muted">Confirmadas y en preparación, por hora de retiro.</p>
<p><a asp-action="Index" class="btn btn-secondary">Panel</a></p>

@if (Model.Count == 0)
{
    <p>No hay órdenes en preparación.</p>
}
else
{
    <div class="row g-3">
        @foreach (var order in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card @(order.Estado == EstadoOrden.Preparando ? "border-warning" : "border-primary") h-100">
                    <div class="card-header d-flex justify-content-between">
                        <strong>Orden #@order.Id</strong>
                        <span class="badge @(order.Estado == EstadoOrden.Preparando ? "bg-warning" : "bg-info")">@order.Estado</span>
                    </div>
                    <div class="card-body">
                        <p class="mb-1"><strong>Retiro:</strong> @(order.HoraRetiro?.ToString("HH:mm") ?? "-")</p>
                        @if (order.Estado == EstadoOrden.Preparando && order.FechaPreparacionInicio.HasValue)
                        {
                            <p><strong>Timer:</strong> <span class="timer fs-4 text-warning" data-inicio="@order.FechaPreparacionInicio.Value.ToString("O")">--:--</span></p>
                        }
                        <ul class="list-unstyled mb-2">
                            @foreach (var item in order.Items) { <li>@item.Cantidad x @item.ProductoNombre</li> }
                        </ul>
                        <p class="mb-2"><strong>@order.Total.ToString("C")</strong></p>
                        @if (order.Estado == EstadoOrden.Confirmada)
                        {
                            <form asp-action="UpdateStatus" asp-route-id="@order.Id" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="accion" value="preparando" />
                                <button type="submit" class="btn btn-warning btn-sm w-100">Iniciar preparación</button>
                            </form>
                        }
                        @if (order.Estado == EstadoOrden.Preparando)
                        {
                            <form asp-action="UpdateStatus" asp-route-id="@order.Id" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="accion" value="lista" />
                                <button type="submit" class="btn btn-success btn-sm w-100">Marcar lista</button>
                            </form>
                        }
                    </div>
                    <div class="card-footer"><a asp-action="Detail" asp-route-id="@order.Id" class="btn btn-outline-secondary btn-sm">Detalle</a></div>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
<script>
function kTick() { document.querySelectorAll('.timer').forEach(el => { const d = Math.floor((Date.now() - new Date(el.dataset.inicio)) / 1000); el.textContent = Math.floor(d/60).toString().padStart(2,'0') + ':' + (d%60).toString().padStart(2,'0'); }); }
kTick(); setInterval(kTick, 1000);
</script>
}
