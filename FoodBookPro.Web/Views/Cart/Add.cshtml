@model List<FoodBookPro.Web.Models.CartItemViewModel>
@{
    ViewData["Title"] = "Agregar al carrito";
}

<h2>Agregar producto al carrito</h2>

<p>Selecciona un producto y la cantidad para agregar.</p>

<div class="row">
    @foreach (var product in Model)
    {
        <div class="col-md-4 mb-3">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">@product.Name</h5>
                    <p class="card-text">@product.Price.ToString("C")</p>
                    <form asp-action="AddItem" method="post">
                        <input type="hidden" name="productId" value="@product.ProductId" />
                        <div class="mb-2">
                            <label>Cantidad:</label>
                            <input type="number" name="quantity" value="1" min="1" class="form-control" style="width: 80px" />
                        </div>
                        <button type="submit" class="btn btn-primary">Agregar al carrito</button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>

<a asp-action="Index" class="btn btn-secondary">Ver carrito</a>
