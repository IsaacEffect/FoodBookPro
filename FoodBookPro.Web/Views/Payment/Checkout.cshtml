@model FoodBookPro.Data.Entities.Order

@{
    ViewData["Title"] = "Finalizar Pago";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-4 order-md-2 mb-4">
            <h4 class="d-flex justify-content-between align-items-center mb-3">
                <span class="text-muted">Tu Orden</span>
                <span class="badge badge-secondary badge-pill">#@Model.Id</span>
            </h4>
            <ul class="list-group mb-3">
                <li class="list-group-item d-flex justify-content-between lh-condensed">
                    <div>
                        <h6 class="my-0">Cliente</h6>
                        <small class="text-muted">@Model.CustomerName</small>
                    </div>
                </li>
                <li class="list-group-item d-flex justify-content-between">
                    <span>Subtotal (USD)</span>
                    <strong>$@Model.Total</strong>
                </li>
            </ul>
        </div>

        <div class="col-md-8 order-md-1">
            <h4 class="mb-3">Método de Pago</h4>
            <form asp-controller="Payment" asp-action="Process" method="post">
                <input type="hidden" name="orderId" value="@Model.Id" />

                <div class="d-block my-3">
                    <div class="custom-control custom-radio">
                        <input id="credit" name="method" type="radio" class="custom-control-input" value="Tarjeta" checked required>
                        <label class="custom-control-label" for="credit">Tarjeta de Crédito/Débito</label>
                    </div>
                    <div class="custom-control custom-radio">
                        <input id="cash" name="method" type="radio" class="custom-control-input" value="Efectivo" required>
                        <label class="custom-control-label" for="cash">Efectivo al Recibir</label>
                    </div>
                </div>

                <hr class="mb-4">

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="tipAmount">¿Deseas agregar propina?</label>
                        <div class="input-group">
                            <div class="input-group-prepend">
                                <span class="input-group-text">$</span>
                            </div>
                            <input type="number" class="form-control" id="tipAmount" name="tipAmount" placeholder="0.00" step="0.01" min="0">
                        </div>
                    </div>
                </div>

                <hr class="mb-4">
                <button class="btn btn-primary btn-lg btn-block" type="submit">Procesar Pago Seguro</button>
            </form>
        </div>
    </div>
</div>