@{
    ViewData["Title"] = "Login";
}

<h2>Inicio de Sesión</h2>

<form method="post">

    <label>Email</label>
    <input type="email" name="email" required />
    <br />

    <label>Contraseña</label>
    <input type="password" name="password" required />
    <br />

    <button type="submit">Iniciar Sesión</button>

</form>